@model Zorgboerderij.Models.AanpasbaarheidViewModel
@{
    ViewData["Title"] = "Aanpasbaarheid";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<div class="container mt-5">
    <div class="text-center mb-4">
        <h2 class="fw-bold">Aanpasbaarheid</h2>
        <p class="text-muted">Pas hieronder de instellingen aan. De logo-optie is optioneel.</p>
    </div>

    @if (TempData["Message"] != null)
    {
        <div class="alert alert-success">@TempData["Message"]</div>
    }

    <form asp-action="Index" method="post" enctype="multipart/form-data">
        <fieldset class="border p-3 mb-4">
            <legend class="w-auto px-2">Logo Instellingen (optioneel)</legend>

           
            @if (!string.IsNullOrEmpty(Model.ExistingLogo))
            {
                <p><strong>Huidig logo:</strong></p>
                <p>@Model.ExistingLogo</p> 
                <img id="currentLogo" src="@Model.ExistingLogo" class="img-fluid" style="max-width: 300px;" />
            }

            <div class="mb-3 mt-3">
                <label asp-for="LogoFile" class="form-label">Upload nieuw logo</label>
                <input asp-for="LogoFile" class="form-control" type="file" accept="image/*" onchange="previewImage(event)" />
                <span asp-validation-for="LogoFile" class="text-danger"></span>
            </div>

            
            <div class="mt-3" id="preview-container" style="display: none;">
                <p>Preview van het geselecteerde logo:</p>
                <img id="logoPreview" class="img-thumbnail" style="max-height: 100px;" />
                <p id="newLogoName"></p> 
            </div>
        </fieldset>

        <button type="submit" class="btn btn-success">Opslaan</button>
    </form>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />

    <script>
        
        function previewImage(event) {
            var reader = new FileReader();
            reader.onload = function () {
                var output = document.getElementById('logoPreview');
                output.src = reader.result;
                document.getElementById('preview-container').style.display = 'block'; 

                
                var newLogoName = event.target.files[0].name;
                document.getElementById('newLogoName').innerText = "Naam van nieuw logo: " + newLogoName;
            }
            reader.readAsDataURL(event.target.files[0]);
        }

        @if (!string.IsNullOrEmpty(Model.ExistingLogo))
        {
            <text>
                // Als er een nieuw logo is, wordt het logo dynamisch vervangen in de afbeelding
                var newLogoUrl = '@Model.ExistingLogo'; // Dit is de URL van het nieuwe logo die na het opslaan van het formulier wordt teruggestuurd
                var logoElement = document.getElementById('currentLogo');
                logoElement.src = newLogoUrl; // Wijzig de src van het huidige logo naar het nieuwe logo
            </text>
        }
    </script>
}
