@model Zorgboerderij.Models.AanpasbaarheidViewModel

@{
    ViewData["Title"] = "Aanpasbaarheid";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<div class="container mt-5">
    <div class="text-center mb-4">
        <h2 class="fw-bold">Aanpasbaarheid</h2>
        <p class="text-muted">Pas hieronder de instellingen aan. De logo-optie is optioneel.</p>
    </div>

    @if (TempData["Message"] != null)
    {
        <div class="alert alert-success">@TempData["Message"]</div>
    }

    <form asp-controller="Aanpasbaarheid" asp-action="Index" method="post" enctype="multipart/form-data">
        <fieldset class="border p-4 rounded shadow-sm mb-4">
            <legend class="w-auto px-2 fw-semibold">Logo Instellingen (optioneel)</legend>

            @if (!string.IsNullOrEmpty(Model.ExistingLogo))
            {
                <div class="mb-3">
                    <p><strong>Huidig logo:</strong></p>
                    <img id="currentLogo" src="@Model.ExistingLogo" class="img-fluid border border-secondary p-2" style="max-width: 300px;" />
                </div>
            }

            <div class="mb-3">
                <label asp-for="LogoFile" class="form-label">Upload nieuw logo</label>
                <input asp-for="LogoFile" class="form-control" type="file" accept="image/*" onchange="previewImage(event)" />
                <span asp-validation-for="LogoFile" class="text-danger"></span>
                <input type="hidden" asp-for="ExistingLogo" />
            </div>

            <div class="mt-3" id="preview-container" style="display: none;">
                <p class="mb-1">Preview van het geselecteerde logo:</p>
                <img id="logoPreview" class="img-thumbnail mb-2" style="max-height: 100px;" />
                <p id="newLogoName" class="text-muted small"></p>
            </div>
        </fieldset>

        <button type="submit" class="btn btn-success px-4">Opslaan</button>
    </form>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />

    <script>
        function previewImage(event) {
            const reader = new FileReader();
            reader.onload = function () {
                const output = document.getElementById('logoPreview');
                output.src = reader.result;
                document.getElementById('preview-container').style.display = 'block';

                const newLogoName = event.target.files[0].name;
                document.getElementById('newLogoName').innerText = "Naam van nieuw logo: " + newLogoName;
            };
            if (event.target.files.length > 0) {
                reader.readAsDataURL(event.target.files[0]);
            }
        }
    </script>
}
