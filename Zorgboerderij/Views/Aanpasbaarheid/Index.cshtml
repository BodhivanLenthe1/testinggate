@model Zorgboerderij.Models.AanpasbaarheidViewModel
@{
    ViewData["Title"] = "Aanpasbaarheid";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<div class="container mt-5">
    <div class="text-center mb-4">
        <h2 class="fw-bold">Aanpasbaarheid</h2>
        <p class="text-muted">Pas hieronder de instellingen aan voor de tijdlijn bij de bezetting. De logo-optie is optioneel.</p>
    </div>

    @if (TempData["Message"] != null)
    {
        <div class="alert alert-success" role="alert">
            @TempData["Message"]
        </div>
    }

    <form asp-action="Index" method="post" enctype="multipart/form-data">
        <fieldset class="border p-3 mb-4">
            <legend class="w-auto px-2">Tijdlijn Instellingen</legend>
            <div class="row mb-3">
                <div class="col-md-6">
                    <label asp-for="StartTime" class="form-label"></label>
                    <input asp-for="StartTime" class="form-control" type="time" />
                    <span asp-validation-for="StartTime" class="text-danger"></span>
                </div>
                <div class="col-md-6">
                    <label asp-for="EndTime" class="form-label"></label>
                    <input asp-for="EndTime" class="form-control" type="time" />
                    <span asp-validation-for="EndTime" class="text-danger"></span>
                </div>
            </div>
        </fieldset>
        <fieldset class="border p-3 mb-4">
            <legend class="w-auto px-2">Logo Instellingen (optioneel)</legend>
            <div class="mb-3">
                <label asp-for="LogoFile" class="form-label"></label>
                <input asp-for="LogoFile" class="form-control" type="file" accept="image/*" />
                <span asp-validation-for="LogoFile" class="text-danger"></span>
            </div>
            @if (!string.IsNullOrEmpty(Model.ExistingLogoUrl))
            {
                <div class="mt-3">
                    <p>Huidig logo:</p>
                    <img src="@Model.ExistingLogoUrl" alt="Huidig logo" class="img-thumbnail" style="max-height: 100px;">
                </div>
            }
        </fieldset>

        <button type="submit" class="btn btn-success">Instellingen opslaan</button>
    </form>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
