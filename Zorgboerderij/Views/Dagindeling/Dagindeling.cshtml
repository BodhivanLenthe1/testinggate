@model IEnumerable<Zorgboerderij.Entities.DagBezettingViewModel>

@{
    ViewData["Title"] = "Dagindeling";
}

<div class="container mt-5">
    <div class="text-center mb-4">
        <h2 class="fw-bold">Selecteer een dag</h2>
        <p class="text-muted">Klik op een dag om de dagindeling te bekijken</p>
    </div>

    <div class="row justify-content-center">
        @foreach (var dag in Model)
        {
            <div class="col-lg-2 col-md-3 col-sm-4 col-6 mb-3 d-flex justify-content-center">
                <a asp-controller="Dagindeling" asp-action="Dag" asp-route-dag="@dag.Dag" style="text-decoration:none; width:100%;">
                    <div class="card h-100 text-center shadow-sm" style="border:2px solid black; border-radius:0.5rem; padding:0.5rem; min-width: 210px; transition: transform 0.2s, background-color 0.2s;"
                         onmouseover="this.style.backgroundColor='#f4fff1';" onmouseout="this.style.backgroundColor='white';">
                        <div style="color:black; font-weight:bold; font-size:1rem;">
                            @dag.Dag
                        </div>
                    </div>
                </a>
            </div>
        }
    </div>
</div>
