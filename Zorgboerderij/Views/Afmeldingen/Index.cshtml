@model IEnumerable<Zorgboerderij.Entities.Afmeldingen>

@{
    ViewData["Title"] = "Index";
}

<h1>Overzicht afmeldingen</h1>

<table class="table">
    <thead>
        <tr>
            <th>
                @Html.DisplayNameFor(model => model.Client)
            </th>
            <th>
                @Html.DisplayNameFor(model => model.Tandarts)
            </th>
            <th>
                @Html.DisplayNameFor(model => model.Vakantie)
            </th>
            <th>
                @Html.DisplayNameFor(model => model.Verjaardag)
            </th>
            <th>
                @Html.DisplayNameFor(model => model.Ziek)
            </th>
            <th>
                @Html.DisplayNameFor(model => model.Vrij)
            </th>
            <th>
                @Html.DisplayNameFor(model => model.Dokter)
            </th>
            <th>
                @Html.DisplayNameFor(model => model.OpKarwei)
            </th>
            <th>

            </th>
        </tr>
    </thead>
    <tbody>
@foreach (var item in Model) {
        <tr>
            <td>
                @Html.DisplayFor(modelItem => item.Client)
            </td>
            <td>
                @Html.DisplayFor(modelItem => item.Tandarts)
            </td>
            <td>
                @Html.DisplayFor(modelItem => item.Vakantie)
            </td>
            <td>
                @Html.DisplayFor(modelItem => item.Verjaardag)
            </td>
            <td>
                @Html.DisplayFor(modelItem => item.Ziek)
            </td>
            <td>
                @Html.DisplayFor(modelItem => item.Vrij)
            </td>
            <td>
                @Html.DisplayFor(modelItem => item.Dokter)
            </td>
            <td>
                @Html.DisplayFor(modelItem => item.OpKarwei)
            </td>
            <td>

            </td>
        </tr>
}
    </tbody>
</table>
