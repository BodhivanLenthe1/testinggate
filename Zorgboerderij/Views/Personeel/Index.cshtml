@model IEnumerable<Zorgboerderij.Entities.Personeel>

@{
    ViewData["Title"] = "Index";
}

<p>
    <p>
        <a asp-action="Create" class="nav-link text-dark"><img src="~/images/person-plus-fill.svg" style="width: 20px;" /><b> Nieuwe collega toevoegen</b></a>
    </p>

    <div class="personeel-container" style="display: flex; flex-wrap: wrap;">
        @foreach (var personeel in Model)
        {
        <div style="margin: 10px; text-align: center;">
            <img src="~/images/Personeel/@personeel.FotoFile" style="width: 225px; height: 125px;" />
            <h3 class="">@personeel.Voornaam @personeel.Achternaam</h3>

            <a asp-action="Edit" asp-route-id="@personeel.persid"><img src="~/images/pencil-square.svg" style="width:25px; margin-bottom: 10px;"/></a>
            <a asp-action="Delete" asp-route-id="@personeel.persid"><img src="~/images/trash3-fill.svg" style="width:25px; margin-bottom: 10px;" /></a>

            <table class="table table-bordered">
                <thead>
                    <th>Ma</th>
                    <th>Di</th>
                    <th>Wo</th>
                    <th>Do</th>
                    <th>Vr</th>
                    <th>Za</th>
                </thead>
                <tbody>
                    <tr>
                        <td>@(personeel.Maandag == 1 ? "X" : "-")</td>
                        <td>@(personeel.Dinsdag == 1 ? "X" : "-")</td>
                        <td>@(personeel.Woensdag == 1 ? "X" : "-")</td>
                        <td>@(personeel.Donderdag == 1 ? "X" : "-")</td>
                        <td>@(personeel.Vrijdag == 1 ? "X" : "-")</td>
                        <td>@(personeel.Zaterdag == 1 ? "X" : "-")</td>
                    </tr>
                </tbody>
            </table>
        </div>
    }
</div>