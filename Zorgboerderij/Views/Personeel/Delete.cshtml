    <form asp-action="Delete">
        <input type="hidden" asp-for="persid" />
        <input type="submit" value="Verwijderen" class="btn btn-danger ms-lg-5" />
        <button asp-action="Index" class="btn btn-success ms-lg-2">Annuleren</button>
    </form>
</div>
