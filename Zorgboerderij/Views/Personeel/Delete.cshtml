@model Zorgboerderij.Entities.Personeel

@{
    ViewData["Title"] = "Delete";
}

<h3>Weet u zeker dat u deze collega wilt verwijderen?</h3>
<div>
    <h4>Personeel</h4>
    <hr />
    <dl class="row">
        <dt class = "col-sm-2">
            @Html.DisplayNameFor(model => model.Voornaam)
        </dt>
        <dd class = "col-sm-10">
            @Html.DisplayFor(model => model.Voornaam)
        </dd>
        <dt class = "col-sm-2">
            @Html.DisplayNameFor(model => model.Achternaam)
        </dt>
        <dd class = "col-sm-10">
            @Html.DisplayFor(model => model.Achternaam)
        </dd>
        <dt class = "col-sm-2">
            @Html.DisplayNameFor(model => model.FotoFile)
        </dt>
        <dd class = "col-sm-10">
            @Html.DisplayFor(model => model.FotoFile)
        </dd>
        <dt class = "col-sm-2">
            @Html.DisplayNameFor(model => model.Maandag)
        </dt>
        <dd class = "col-sm-10">
            @Html.DisplayFor(model => model.Maandag)
        </dd>
        <dt class = "col-sm-2">
