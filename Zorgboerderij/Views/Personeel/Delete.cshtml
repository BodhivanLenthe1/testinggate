        <dd class = "col-sm-10">
            @Html.DisplayFor(model => model.Dinsdag)
        </dd>
        <dt class = "col-sm-2">
            @Html.DisplayNameFor(model => model.Woensdag)
        </dt>
        <dd class = "col-sm-10">
            @Html.DisplayFor(model => model.Woensdag)
