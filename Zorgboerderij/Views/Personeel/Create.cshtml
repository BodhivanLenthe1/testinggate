                    <option value="Cilia Huuskes Stage.jpg">Cilia</option>
                    <option value="Cor.jpg">Cor</option>
                    <option value="Desiree stage.jpg">Desiree</option>
                    <option value="Diana stage.jpg">Diana</option>
                    <option value="Dunja stage.jpg">Dunja</option>
                    <option value="Dylan.jpg">Dylan</option>
                    <option value="Eline stage.jpg">Eline</option>
                    <option value="Elke.jpg">Elke</option>
                    <option value="Femke D.jpg">Femke</option>
                    <option value="Harrie.jpg">Harrie</option>
                    <option value="Helma.jpg">Helma</option>
                    <option value="Huis.jpg">Huis</option>
                    <option value="Ingrid N.jpg">Ingrid N</option>
                    <option value="Ingrid.jpg">Ingrid</option>
                    <option value="Jan-Willem.jpg">Jan-Willem</option>
                    <option value="Jeroen.jpg">Jeroen</option>
                    <option value="Jessica.jpg">Jessica</option>
                    <option value="Joëlle.jpg">Joëlle</option>
                    <option value="Joost Alofs Stage.jpg">Joost</option>
                    <option value="Jose.jpg">Jose</option>
                    <option value="Koen v. S..jpg">Anouk</option>
                    <option value="Linda.jpg">Linda</option>
                    <option value="Lonneke.jpg">Lonneke</option>
                    <option value="Louis.jpg">Louis</option>
                    <option value="Luka.jpg">Luka</option>
                    <option value="Mariska.jpg">Mariska</option>
                    <option value="Marjo.jpg">Marjo</option>
                    <option value="Maury.jpg">Maury</option>
                    <option value="Meghan.jpg">Meghan</option>
                    <option value="Merel stage.jpg">Merel</option>
                    <option value="Mitchel.jpg">Mitchel</option>
                    <option value="Nina.jpg">Nina</option>
                    <option value="Nout.jpg">Nout</option>
                    <option value="Sanne Evers.jpg">Sanne</option>
                    <option value="Sebastian stage.jpg">Sebastian</option>
                    <option value="Siebren.jpg">Siebren</option>
                    <option value="Suzan stage.jpg">Suzan</option>
                    <option value="Theo.jpg">Theo</option>
                    <option value="Toon.jpg">Toon</option>
                    <option value="Trout.jpg">Trout</option>
                    <option value="Veronique.jpg">Veronique</option>
                </select>
                <span asp-validation-for="FotoFile" class="text-danger"></span>
            </div>

            <div class="form-group">
                <label asp-for="Maandag" class="control-label"></label>
                <div>
                    <label>
                        <input asp-for="Maandag" type="radio" value="1" /> Aanwezig
                    </label>
                    <label>
                        <input asp-for="Maandag" type="radio" value="0" /> Afwezig
                    </label>
                </div>
                <span asp-validation-for="Maandag" class="text-danger"></span>
            </div>
            <div class="form-group">
                <label asp-for="Dinsdag" class="control-label"></label>
                <div>
                    <label>
                        <input asp-for="Dinsdag" type="radio" value="1" /> Aanwezig
                    </label>
                    <label>
                        <input asp-for="Dinsdag" type="radio" value="0" /> Afwezig
                    </label>
                </div>
                <span asp-validation-for="Dinsdag" class="text-danger"></span>
            </div>
            <div class="form-group">
                <label asp-for="Woensdag" class="control-label"></label>
