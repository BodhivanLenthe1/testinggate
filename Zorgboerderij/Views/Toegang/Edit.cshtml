@model Zorgboerderij.Entities.UserAccount

@{
    ViewData["Title"] = "Edit";
}

<h1 class="text-center">Gebruiker aanpassen</h1>

<hr />
<div class="d-flex justify-content-center">
    <div class="col-md-5">
        <form asp-action="Edit">
            <div asp-validation-summary="ModelOnly" class="text-danger"></div>
            <input type="hidden" asp-for="Id" />
            <div class="form-group">
                <label asp-for="OrgId" class="control-label"></label>
                <input asp-for="OrgId" class="form-control" />
                <span asp-validation-for="OrgId" class="text-danger"></span>
            </div>
            <div class="form-group">
                <label asp-for="Voornaam" class="control-label"></label>
                <input asp-for="Voornaam" class="form-control" />
                <span asp-validation-for="Voornaam" class="text-danger"></span>
            </div>
            <div class="form-group">
                <label asp-for="Achternaam" class="control-label"></label>
                <input asp-for="Achternaam" class="form-control" />
                <span asp-validation-for="Achternaam" class="text-danger"></span>
            </div>
            <div class="form-group">
                <label asp-for="Email" class="control-label"></label>
                <input asp-for="Email" class="form-control" />
                <span asp-validation-for="Email" class="text-danger"></span>
            </div>
            <div class="form-group">
                <label asp-for="Gebruikersnaam" class="control-label"></label>
                <input asp-for="Gebruikersnaam" class="form-control" />
                <span asp-validation-for="Gebruikersnaam" class="text-danger"></span>
            </div>
            <div class="form-group">
                <label asp-for="Wachtwoord" class="control-label"></label>
                <input asp-for="Wachtwoord" class="form-control" type="password"/>
                <span asp-validation-for="Wachtwoord" class="text-danger"></span>
            </div>
            <div class="form-group mt-2">
                <input type="submit" value="Gebruiker aanpassen" class="btn btn-primary w-100 mb-2" />
                <p class="text-center"><a asp-action="Index" class="nav-link text-dark">Terug</a></p>
            </div>
        </form>
    </div>
</div>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
}
