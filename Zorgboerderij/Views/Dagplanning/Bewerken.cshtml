@{
    ViewData["Title"] = "Dagplanning";
    var client = Model.Client;
    var kleurOmschrijvingen = new Dictionary<string, string>
    {
        {"blauw","Dieren"},{"paars","Verzorgen"},{"groen","Tuin"},
        {"oranje","Land"},{"geel","Corvee"},{"rood","Creatief"},
        {"grijs","Schuur"},{"zwart","Klussen"},{"bruin","Tijden"},
        {"lichtgroen","Test"}
    };
    var kleurMap = new Dictionary<string, string>
    {
        {"rood","red"},{"geel","yellow"},{"groen","green"},
        {"blauw","blue"},{"paars","purple"},{"oranje","orange"},
        {"grijs","gray"},{"zwart","black"},{"bruin","saddlebrown"}
    };
}
<div class="container my-4">
    <h2>@ViewData["Title"]</h2>

    <div class="row">
        <div class="col-md-3 mb-4">
            <div class="mb-2">
                <input id="searchInput" type="text" class="form-control" placeholder="Zoeken…">
            </div>
            <div class="mb-3">
                <select id="kleurSort" class="form-select">
                    <option value="">Alle activiteiten</option>
                         <option value="rood">Creatief</option>
                         <option value="groen">Tuin</option> -->
                </select>
            </div>
            <div id="bakjes" class="connectedSortable"
                 style="min-height:400px;border:1px solid #ccc;padding:10px;
                        border-radius:6px;background:#fafafa;overflow-y:auto;">
                <div class="photoItem mb-2 p-2 text-center" data-id="1" data-kleur="rood">
                  <div class="fw-semibold text-truncate">Creatief</div>
                  <img src="/images/placeholder.jpg" alt="Creatief" class="img-fluid rounded mt-1" style="aspect-ratio:1/1;object-fit:cover;">
                </div>
            </div>
        </div>

        <div class="col-md-9">
            <div id="planningTimeline" class="connectedSortable d-flex flex-wrap gap-2 p-3"
                 style="min-height:400px;border:2px dashed #aaa;
                        border-radius:6px;background:#f9f9f9;overflow-x:auto;">
                <div class="photoItem p-2 text-center" data-id="1" data-extra="0">
                  <div class="fw-semibold text-truncate">Ochtendroutine</div>
                  <img src="/images/placeholder.jpg" alt="Ochtendroutine" class="img-fluid rounded mt-1" style="aspect-ratio:1/1;object-fit:cover;">
                </div>

            </div>
        </div>
    </div>

    <form id="saveForm" asp-action="SavePlanning" method="post" class="mt-4">
        <input type="hidden" id="volgordeInput" name="nieuweVolgorde" />
        <button type="submit" class="btn btn-success">💾 Opslaan</button>
    </form>
</div>

<link rel="stylesheet" href="https://code.jquery.com/ui/1.13.2/themes/base/jquery-ui.css" />
@section Scripts {
    <script src="https://code.jquery.com/jquery-3.6.0.min.js"></script>
    <script src="https://code.jquery.com/ui/1.13.2/jquery-ui.min.js"></script>
    <script>
        $(function() {
            function renderBakjes() {
                const sel = $('#kleurSort').val();
                const q   = $('#searchInput').val().toLowerCase();
                $('#bakjes .photoItem').each(function() {
                    const $it    = $(this);
                    const kleur  = $it.data('kleur');
                    const title  = $it.find('.fw-semibold').text().toLowerCase();
                    $it.toggle((!sel || kleur === sel) && title.includes(q));
                });
            }
            $('#kleurSort, #searchInput').on('change keyup', renderBakjes);

            $('.connectedSortable').sortable({
                connectWith: '.connectedSortable',
                placeholder: 'sortable-placeholder',
                forcePlaceholderSize: true,
                helper: 'clone'
            }).disableSelection();

            $('#saveForm').on('submit', function() {
                const volg = [];
                $('#planningTimeline .photoItem').each(function() {
                    const id      = $(this).data('id');
                    const isExtra = $(this).data('extra') ? 1 : 0;
                    volg.push(`${id}:${isExtra}`);
                });
                $('#volgordeInput').val(volg.join(','));
            });
        });
    </script>
}
