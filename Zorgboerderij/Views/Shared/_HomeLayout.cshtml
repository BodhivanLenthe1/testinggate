<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - Zorgboerderij</title>
    <script type="importmap"></script>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/Zorgboerderij.styles.css" asp-append-version="true" />
</head>
<body style="min-height: 100vh; display: flex; flex-direction: column;">

    <header>
        <nav class="navbar navbar-expand-sm navbar-light bg-white border-bottom box-shadow mb-3">
            <div class="d-flex justify-content-center w-100" style="margin-left: 140px;">
                <img src="~/images/LogoBoerderij.png" class="img-fluid" style="width: 350px;">
            </div>
            @await Html.PartialAsync("_PartialLayout")
        </nav>
    </header>

    <div class="container" style="flex: 1;">
        <main role="main" class="pb-3" style="flex-grow: 1;">
            @RenderBody()
        </main>
    </div>

    <footer class="border-top footer text-muted">
        <div class="container text-center py-3">
            <b>Gebruikersovereenkomst:</b> Demo Planbord ICT@Work | ICT@School
        </div>
    </footer>
    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
