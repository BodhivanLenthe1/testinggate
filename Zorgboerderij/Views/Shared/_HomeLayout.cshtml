@{
    bool magNietTerug = Context.Items.ContainsKey("MagNietTerug")
                     && (bool)Context.Items["MagNietTerug"]!;

    var logoDir = System.IO.Path.Combine(System.IO.Directory.GetCurrentDirectory(), "wwwroot", "images", "Logo");
    var logoFiles = System.IO.Directory.GetFiles(logoDir);
    var logoPath = logoFiles.Length > 0
        ? "/images/Logo/" + System.IO.Path.GetFileName(logoFiles[0])
        : null;

}
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - Zorgboerderij</title>
    <script type="importmap"></script>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/Zorgboerderij.styles.css" asp-append-version="true" />
</head>
<body style="min-height: 100vh; display: flex; flex-direction: column;">

    <header>
        <nav class="navbar navbar-expand-sm navbar-light bg-white border-bottom box-shadow mb-3">
            <div class="d-flex justify-content-center w-100" style="margin-left: 140px;">
                @if (logoPath != null)
                {
                    <img src="@logoPath" class="img-fluid" style="width: 350px;" />
                }
            </div>
            @await Html.PartialAsync("_PartialLayout")
        </nav>
    </header>

    <div class="container" style="flex: 1;">
        <main role="main" class="pb-3" style="flex-grow: 1;">
            @RenderBody()
        </main>
    </div>

    <footer class="border-top footer text-muted">
        <div class="container text-center py-3">
            <b>Gebruikersovereenkomst:</b> Demo Planbord ICT@Work | ICT@School
        </div>
    </footer>
    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
@if (magNietTerug)
{
    <div id="dagcodeModal" class="modal fade show" tabindex="-1" style="display:block; background:rgba(0,0,0,0.4);">
        <div class="modal-dialog modal-dialog-centered">
            <div class="modal-content rounded-3 shadow-lg">
                <div class="modal-header border-0">
                    <h5 class="modal-title">Dagcode nodig</h5>
                </div>
                <div class="modal-body">
                    <form id="dagcodeForm">
                        <input type="hidden" id="gebruikersnaam" value="@(Context.Session.GetString("Dagcode"))" />
                        <div class="mb-3">
                            <label for="wachtwoord" class="form-label">Wachtwoord</label>
                            <input type="password" id="wachtwoord" class="form-control" required />
                        </div>
                        <div id="loginFout" class="text-danger mb-2" style="display:none;"></div>
                    </form>
                </div>
                <div class="modal-footer border-0">
                    <button id="annuleerBtn" type="button" class="btn btn-outline-secondary">Annuleren</button>
                    <button id="inloggenBtn" type="button" class="btn btn-primary">Inloggen</button>
                </div>
            </div>
        </div>
    </div>
    <script>
        document.addEventListener("DOMContentLoaded", function() {
          var dagcode      = '@(Context.Session.GetString("Dagcode") ?? "")';
          var path         = window.location.pathname.toLowerCase();
          var magNietTerug = dagcode &&
              !path.includes("/dagplanning/dagkeuze") &&
              !path.includes("/dagplanning/bewerken") &&
              !path.includes("/dagindeling/client");

          if (magNietTerug) {
            document.getElementById("dagcodeModal").style.display = "block";
          }

          var annuleerBtn = document.getElementById("annuleerBtn");
          var inloggenBtn = document.getElementById("inloggenBtn");
          var wwField     = document.getElementById("wachtwoord");

          annuleerBtn.addEventListener("click", function() {
            window.location.href = `/Dagplanning/Dagkeuze?dag=${encodeURIComponent(dagcode)}`;
          });

          inloggenBtn.addEventListener("click", function() {
            var gebruikersnaam = dagcode;      // rechtstreeks uit sessie
            var wachtwoord    = wwField.value;

            fetch("@Url.Action("CheckDagcode", "Dagplanning")", {
              method: "POST",
              headers: {"Content-Type":"application/x-www-form-urlencoded"},
              body: `gebruikersnaam=${encodeURIComponent(gebruikersnaam)}&wachtwoord=${encodeURIComponent(wachtwoord)}`
            })
            .then(r => r.json())
            .then(json => {
              if (json.success) {
                location.reload();
              } else {
                var f = document.getElementById("loginFout");
                f.innerText = "Ongeldige dagcode of wachtwoord.";
                f.style.display = "block";
              }
            });
          });

          wwField.addEventListener("keydown", function(e) {
            if (e.key === "Enter") {
              e.preventDefault();
              inloggenBtn.click();
            }
          });
        });
    </script>

}
</html>
