@model Zorgboerderij.Models.LoginVM

@{
    ViewData["Title"] = "Login";
    Layout = "_LoginLayout";
}

<h1 class="text-center">Inloggen</h1>

<div class="d-flex justify-content-center">
    <div class="col-md-5">
        <form asp-action="Login">
            <div asp-validation-summary="ModelOnly" class="text-danger"></div>
            <div class="form-group">
                <label asp-for="OrgId" class="control-label"></label>
                <input asp-for="OrgId" class="form-control" />
                <span asp-validation-for="OrgId" class="text-danger"></span>
            </div>
            <div class="form-group">
                <label asp-for="Gebruikersnaam" class="control-label"></label>
                <input asp-for="Gebruikersnaam" class="form-control" />
                <span asp-validation-for="Gebruikersnaam" class="text-danger"></span>
            </div>
            <div class="form-group">
                <label asp-for="Wachtwoord" class="control-label"></label>
                <input asp-for="Wachtwoord" class="form-control" />
                <span asp-validation-for="Wachtwoord" class="text-danger"></span>
            </div>
            <div class="form-group mt-3 mb-5">
                <input type="submit" value="Login" class="btn btn-primary w-100" />
            </div>
        </form>
    </div>
</div>

<div class="d-flex flex-column justify-content-center align-items-center">
    <p>We hebben het volgende IP-adres opgeslagen: 91.220.53.88</p>
    <p class="opacity-50">© 2000 - 2024 / ICT@Work | ICT@School</p>
    <p>Powered by:</p>
</div>

<div class="d-flex justify-content-center">
    <img class="mt-3 p-3" src="~/images/ictatwork-logo-header.png" width="25%" />
    <img class="mt-3 p-2" src="~/images/elopartner.logo.png" width="25%" />
</div>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
}
