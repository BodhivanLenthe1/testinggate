@model Zorgboerderij.Entities.Dagcodes

@{
    ViewData["Title"] = "Dagcode Aanpassen";
}

<div class="d-flex justify-content-center align-items-center" style="min-height: 60vh;">
    <div class="card shadow-lg border-0 rounded-4 p-4" style="width: 100%; max-width: 500px;">
        <div class="text-white text-center mb-4 py-3 px-2 rounded-3"
             style="background: linear-gradient(135deg, #4374b8, #4374b8); box-shadow: 0 4px 10px rgba(0,0,0,0.15);">
            <h4 class="mb-0">🗓️ Dagcode Aanpassen</h4>
        </div>
        <div class="card-body">
            <form asp-action="Edit">
                <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>
                <input type="hidden" asp-for="Id" />

                <div class="form-group mb-3">
                    <label asp-for="Dag" class="form-label">Dag</label>
                    <input asp-for="Dag" class="form-control" readonly />
                    <span asp-validation-for="Dag" class="text-danger"></span>
                </div>

                <div class="form-group mb-3">
                    <label asp-for="DagCode" class="form-label">Dagcode</label>
                    <input asp-for="DagCode" class="form-control" />
                    <span asp-validation-for="DagCode" class="text-danger"></span>
                </div>

                <div class="form-group mt-3">
                    <input type="submit" value="Dagcode Aanpassen" class="btn w-100 mb-2 text-white"
                           style="background: linear-gradient(135deg, #4374b8, #4374b8); border: none;" />
                    <p class="text-center mb-0">
                        <a asp-action="Index" class="nav-link text-dark">Terug</a>
                    </p>
                </div>
            </form>
        </div>
    </div>
</div>
