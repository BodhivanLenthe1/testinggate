@model Zorgboerderij.Entities.Clienten

@{
    ViewData["Title"] = "Cliënt Aanmaken";
}

<div class="d-flex justify-content-center">
    <div class="col-md-5">
        <form asp-controller="Clienten" asp-action="Create" method="post" enctype="multipart/form-data" class="p-3 rounded shadow">
            <h4 class="text-center mb-2">@ViewData["Title"]</h4>

            <div asp-validation-summary="ModelOnly" class="alert alert-danger"></div>

            <div class="row mb-2">
                <div class="col">
                    <label asp-for="Voornaam" class="form-label fw-bold"></label>
                    <input asp-for="Voornaam" class="form-control form-control-sm" required />
                </div>
                <div class="col">
                    <label asp-for="Achternaam" class="form-label fw-bold"></label>
                    <input asp-for="Achternaam" class="form-control form-control-sm" required />
                </div>
            </div>

            <div class="mb-2">
                <label class="form-label fw-bold">Upload een foto</label>
                <input type="file" name="Foto" class="form-control form-control-sm" accept="image/*" />
            </div>

            @foreach (var dag in new[] { "Maandag", "Dinsdag", "Woensdag", "Donderdag", "Vrijdag", "Zaterdag" })
            {
                <div class="form-group mb-2 p-2">
                    <label class="fw-bold">@dag</label>
                    <div class="d-flex gap-3">
                        <div class="form-check">
                            <input type="radio" class="form-check-input" name="@dag" value="O">
                            <label class="form-check-label text-success">Ochtend</label>
                        </div>
                        <div class="form-check">
                            <input type="radio" class="form-check-input" name="@dag" value="M">
                            <label class="form-check-label text-warning">Middag</label>
                        </div>
                        <div class="form-check">
                            <input type="radio" class="form-check-input" name="@dag" value="H">
                            <label class="form-check-label text-primary">Hele dag</label>
                        </div>
                        <div class="form-check">
                            <input type="radio" class="form-check-input" name="@dag" value="X" checked>
                            <label class="form-check-label text-danger">Afwezig</label>
                        </div>
                    </div>
                </div>
            }

            <div class="mb-2">
                <label asp-for="Groepskleur" class="form-label fw-bold"></label>
                <select class="form-select form-select-sm" asp-for="Groepskleur">
                    <option value="Geel">Geel</option>
                    <option value="Rood">Rood</option>
                    <option value="Blauw">Blauw</option>
                </select>
            </div>

            <div class="mt-2 text-center">
                <button type="submit" class="btn btn-success btn-sm w-100">Opslaan</button>
                <a asp-action="Index" class="btn btn-outline-secondary btn-sm mt-2 w-100">Terug</a>
            </div>
        </form>
    </div>
</div>

