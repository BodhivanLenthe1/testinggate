@model Zorgboerderij.Entities.Clienten

@{
    ViewData["Title"] = "Create";
}

<div class="d-flex justify-content-center">
    <div class="col-md-5">
        <form asp-action="Create">
            <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>

            <div class="form-group mb-3">
                <label asp-for="Voornaam" class="control-label text-primary"></label>
                <input asp-for="Voornaam" class="form-control" />
                <span asp-validation-for="Voornaam" class="text-danger"></span>
            </div>

            <div class="form-group mb-3">
                <label asp-for="Achternaam" class="control-label text-primary"></label>
                <input asp-for="Achternaam" class="form-control" />
                <span asp-validation-for="Achternaam" class="text-danger"></span>
            </div>

            <div class="form-group mb-3">
                <label asp-for="FotoFile" class="control-label text-primary"></label>
                <select class="form-select" asp-for="FotoFile">
                    <option value="Davy.jpg">Davy</option>
                    <option value="Eric S.jpg">Eric</option>
                    <option value="Walter.jpg">Walter</option>
                    <option value="Qutaiba.jpg">Qutaiba</option>
                </select>
                <span asp-validation-for="FotoFile" class="text-danger"></span>
            </div>

            @foreach (var dag in new[] { "Maandag", "Dinsdag", "Woensdag", "Donderdag", "Vrijdag", "Zaterdag" })
            {
                <div class="form-group mb-3">
                    <label asp-for="@dag" class="control-label text-primary">@dag</label>
                    <div>
                        <label class="text-success">
                            <input type="radio" name="@dag-Status" value="1" onclick="toggleTimeOptions('@dag', true)" /> Aanwezig
                        </label>
                        <label class="text-danger">
                            <input type="radio" name="@dag-Status" value="0" onclick="toggleTimeOptions('@dag', false)" /> Afwezig
                        </label>
                    </div>

                    <div id="@dag-TimeOptions" class="time-options mt-2" style="display: none;">
                        <label class="text-primary">Keuze tijd</label><br />
                        <label>
                            <input type="radio" name="@dag-Time" value="Ochtend" /> Ochtend
                        </label>
                        <label>
                            <input type="radio" name="@dag-Time" value="Middag" /> Middag
                        </label>
                        <label>
                            <input type="radio" name="@dag-Time" value="Hele dag" /> Hele dag
                        </label>
                    </div>

                    <span asp-validation-for="@dag" class="text-danger"></span>
                </div>
            }

           
            <div class="form-group mb-3">
                <label asp-for="Goepskleur" class="control-label text-primary"></label>
                <select class="form-select" asp-for="Goepskleur">
                    <option value="Geel">Geel</option>
                    <option value="Rood">Rood</option>
                    <option value="Blauw">Blauw</option>
                </select>
                <span asp-validation-for="Goepskleur" class="text-danger"></span>
            </div>

            <div class="form-group mt-3">
                <input type="submit" value="Collega aanmaken" class="btn btn-success w-100 mb-2" />
                <p class="text-center"><a asp-action="Index" class="nav-link text-dark">Terug</a></p>
            </div>
        </form>
    </div>
</div>

<script>
    // Functie om de tijdopties te tonen/verbergen
    function toggleTimeOptions(day, isPresent) {
        // Verberg eerst alle tijdopties
        var timeOptions = document.querySelectorAll('.time-options');
        timeOptions.forEach(function (option) {
            option.style.display = 'none';
        });

        // Als de dag "Aanwezig" is, toon de tijdopties
        if (isPresent) {
            var selectedDay = document.getElementById(day + '-TimeOptions');
            if (selectedDay) {
                selectedDay.style.display = 'block';
            }
        } else {
            var selectedDay = document.getElementById(day + '-TimeOptions');
            if (selectedDay) {
                selectedDay.style.display = 'none';
            }
        }

        // Reset de radio knoppen voor de andere status (om ervoor te zorgen dat de knoppen niet vast blijven staan)
        var radios = document.querySelectorAll(`input[name='${day}-Status']`);
        radios.forEach(function (radio) {
            radio.checked = false;
        });
        // Markeer de geselecteerde knop
        var selectedRadio = document.querySelector(`input[name='${day}-Status'][value='${isPresent ? '1' : '0'}']`);
        if (selectedRadio) {
            selectedRadio.checked = true;
        }
    }

</script>
