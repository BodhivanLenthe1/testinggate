@model IEnumerable<Zorgboerderij.Entities.Clienten>
@{
    ViewData["Title"] = "Clienten";
}
<div class="d-flex justify-content-between align-items-center mb-4">
    <h1>@ViewData["Title"]</h1>
    <div class="input-group" style="max-width: 300px;">
        <input type="text" class="form-control" placeholder="Zoeken..." id="searchInput"
               onkeyup="searchList('searchInput', '.client-row')" />
        <span class="input-group-text">
            <img src="~/images/search.svg" style="width: 20px;" />
        </span>
    </div>
</div>
<p>
    <a asp-action="Create" class="btn btn-primary btn-sm d-flex align-items-center p-2" style="max-width: 250px; background: #3fa21d; font-weight: 500; border-radius: 16px;">
        <img src="~/images/person-plus-fill.svg" class="me-2" style="width: 18px;" />
        Nieuw client toevoegen
    </a>
</p>
<ul class="list-group mt-4">
    @foreach (var client in Model)
    {
        <li class="list-group-item" style="border-radius: 16px; border-bottom: groove;">
            <div class="d-flex justify-content-between align-items-center client-row p-3"
                 onclick="toggleDetails('@client.persid', 'client-details', 'clientDetails-')"
                 style="cursor: pointer;">
                <div class="d-flex align-items-center">
                    <h5 class="mb-0 me-3" style="font-weight: 600;">@client.Voornaam @client.Achternaam</h5>
                </div>
                <div onclick="event.stopPropagation();">
                    <a asp-action="Edit" asp-route-id="@client.persid" class="btn btn-outline-primary btn-sm me-2">
                        <img src="~/images/pencil-square.svg" style="width: 18px;" />
                    </a>
                    <a asp-action="Delete" asp-route-id="@client.persid" class="btn btn-outline-danger btn-sm">
                        <img src="~/images/trash3-fill.svg" style="width: 18px;" />
                    </a>
                </div>
            </div>
            <div id="clientDetails-@client.persid" class="client-details mt-3" style="display: none; overflow: hidden; max-height: 0; opacity: 0; transition: max-height 0.5s ease, opacity 0.4s ease;">
                <div class="card">
                    <div class="card-body">
                        <div class="row">
                            <div class="col-md-6">
                                <dl class="row">
                                    <dt class="col-sm-4">Voornaam</dt>
                                    <dd class="col-sm-8">@client.Voornaam</dd>

                                    <dt class="col-sm-4">Achternaam</dt>
                                    <dd class="col-sm-8">@client.Achternaam</dd>

                                    @if (!string.IsNullOrEmpty(client.FotoFile))
                                    {
                                        <dt class="col-sm-4">Foto</dt>
                                        <dd class="col-sm-8">
                                            <img src="~/images/clienten/@client.FotoFile" style="max-width: 150px; max-height: 150px;" class="img-thumbnail" alt="Foto van @client.Voornaam" />
                                        </dd>
                                    }

                                    <dt class="col-sm-4">Groepskleur</dt>
                                    <dd class="col-sm-8">
                                        <span class="badge" style="background-color: @client.Groepskleur ">@client.Groepskleur</span>
                                    </dd>
                                </dl>
                            </div>
                            <div class="col-md-6">
                                <h6 class="mb-3">Dagen aanwezig:</h6>
                                <table class="table table-bordered table-sm">
                                    <thead>
                                        <tr>
                                            <th>Dag</th>
                                            <th>Aanwezigheid</th>
                                        </tr>
                                    </thead>
                                    <tbody>
                                        <tr>
                                            <td>Maandag</td>
                                            <td>@Html.Raw(GetAanwezigheidBadge(client.Maandag))</td>
                                        </tr>
                                        <tr>
                                            <td>Dinsdag</td>
                                            <td>@Html.Raw(GetAanwezigheidBadge(client.Dinsdag))</td>
                                        </tr>
                                        <tr>
                                            <td>Woensdag</td>
                                            <td>@Html.Raw(GetAanwezigheidBadge(client.Woensdag))</td>
                                        </tr>
                                        <tr>
                                            <td>Donderdag</td>
                                            <td>@Html.Raw(GetAanwezigheidBadge(client.Donderdag))</td>
                                        </tr>
                                        <tr>
                                            <td>Vrijdag</td>
                                            <td>@Html.Raw(GetAanwezigheidBadge(client.Vrijdag))</td>
                                        </tr>
                                        <tr>
                                            <td>Zaterdag</td>
                                            <td>@Html.Raw(GetAanwezigheidBadge(client.Zaterdag))</td>
                                        </tr>
                                    </tbody>
                                </table>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </li>
    }
</ul>

@functions {
    public string GetAanwezigheidBadge(string aanwezigheid)
    {
        string badgeClass = "";
        string text = "";

        switch (aanwezigheid?.ToUpper())
        {
            case "O":
                badgeClass = "bg-info";
                text = "Ochtend";
                break;
            case "M":
                badgeClass = "bg-warning";
                text = "Middag";
                break;
            case "H":
                badgeClass = "bg-success";
                text = "Hele dag";
                break;
            case "X":
            default:
                badgeClass = "bg-secondary";
                text = "Afwezig";
                break;
        }

        return $"<span class=\"badge {badgeClass}\">{text}</span>";
    }
}

